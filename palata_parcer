import requests
from lxml import html
import time
import urllib3
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
HEADERS = {
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
}
m_m = {
    'января': '01',
    'февраля': '02',
    'марта': '03',
    'апреля': '04',
    'мая': '05',
    'июня': '06',
    'июля': '07',
    'августа': '08',
    'сентября': '09',
    'октября': '10',
    'ноября': '11',
    'декабря': '12'
}
pages = 3 # ammount of parsed pages
def parse_news():
    results = []
    for j in range(1,pages):
        print(j)
        base_url = 'https://palata-nk.ru/about/news/?day=all&PAGEN_1=' + str(j)
        response = requests.get(base_url, headers=HEADERS, verify=False)
        response.raise_for_status()
        tree = html.fromstring(response.content)
        # Все блоки статей: /html/body/main/div[2]/div[1]/div
        articles = tree.xpath('/html/body/main/div[2]/div[1]/div')
        for i, article_div in enumerate(articles, start=1):
            # Ссылка: ./div/div[2]/a[1]
            link_elem = article_div.xpath('./div/div[2]/a[1]')
            if not link_elem:

                continue
            link_elem = link_elem[0]

            # --- 1. Ссылка на статью ---
            link = link_elem.get('href')
            if not link:
                continue
            if link.startswith('/'):
                link = 'https://palata-nk.ru' + link

            # --- 2. Заголовок из атрибута title ---
            title = link_elem.get('title', '').strip()
            if not title:
                # Запасной вариант, если title вдруг пуст (не должно быть по структуре)
                title = link_elem.xpath('string()').strip()

            # --- 3. Фильтр по слову "налог" (без учёта регистра) ---
            if 'налог' not in title.lower() and 'ндс' not in title.lower() and 'фнс' not in title.lower():
                continue

            # --- 4. Дата (raw_data) из span внутри ссылки ---
            raw_span = link_elem.xpath('./span/text()')
            raw_data = raw_span[0].strip() if raw_span else ''

            # --- 5. Переход на страницу статьи ---
            try:
                art_resp = requests.get(link, headers=HEADERS, verify=False)
                art_resp.raise_for_status()
                art_tree = html.fromstring(art_resp.content)
            except Exception as e:
                print(f'Ошибка при загрузке статьи {link}: {e}')
                continue

            # --- 6. Контент статьи по абсолютному пути ---
            # Пробуем точный абсолютный путь
            content_divs = art_tree.xpath('/html/body/main/div/div[1]/div[1]/article/div/div[2]')
            if not content_divs:
                # Запасной вариант – поиск по классу article__content
                content_divs = art_tree.xpath('//div[contains(@class, "article__content")]')
            if not content_divs:
                # Если совсем ничего не найдено – сообщим и выведем кусочек HTML для диагностики
                print(f'Контейнер с текстом не найден на странице: {link}')
                # Печатаем первые 500 символов body, чтобы понять структуру
                body_text = art_tree.xpath('//body')[0].text_content().strip()
                print('Начало текста страницы:', body_text[:200])
                continue

            content_div = content_divs[0]
            # Собираем весь текст внутри контейнера, игнорируя теги
            # itertext() обходит все текстовые узлы в правильном порядке
            text = ' '.join(content_div.itertext())
            data = raw_data.split()
            #print(f'{data[0]}.{m_m[data[1]]}.{data[2]}')
            day = data[0]
            if len(day)==1:
                day = '0'+day
            results.append({
                'raw_data': f'{day}.{m_m[data[1]]}.{data[2]}',
                'title': title,
                'text': text,
                'link': link
            })
            print(title)
            print(link)
            # Пауза между запросами
            time.sleep(1)
    return results

if __name__ == '__main__':
    import pandas as pd
    data = parse_news()
    print(f'Найдено статей: {len(data)}')
    if data:
        df = pd.DataFrame(data)
        df.to_excel('news_nalog.xlsx', index=False)
        print('Данные сохранены в news_nalog.xlsx')
